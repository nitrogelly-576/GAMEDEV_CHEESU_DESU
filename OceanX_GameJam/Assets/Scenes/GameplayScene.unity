  m_TagString: Untagged
  m_Icon: {fileID: 0}
  m_NavMeshLayer: 0
  m_StaticEditorFlags: 0
  m_IsActive: 1
--- !u!114 &1421031221
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1421031220}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: a2b878c1b0778e244aa3bd0e9970ed64, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  _dialogueManager: {fileID: 1737419913}
  _dialogue:
  - Character:
      CharacterName: ???
      Portrait: {fileID: 21300000, guid: 2857a1a9d263fd148bd437f63cdd3e9e, type: 3}
      PortraitOffset: {x: -200, y: 200}
      PortraitScale: 10
    Text: "Oh, you\u2019ve finally arrived! Welcome aboard the Ocean Y, you must
      be the new Captain around here! \n\n(Press Space to continue)\r"
  - Character:
      CharacterName: Thomas
      Portrait: {fileID: 21300000, guid: 2857a1a9d263fd148bd437f63cdd3e9e, type: 3}
      PortraitOffset: {x: -200, y: 200}
      PortraitScale: 10
    Text: "This is Thomas speaking, I\u2019ll be your guide through the day.\r\n"
  - Character:
      CharacterName: Thomas
      Portrait: {fileID: 21300000, guid: 2857a1a9d263fd148bd437f63cdd3e9e, type: 3}
      PortraitOffset: {x: -200, y: 200}
      PortraitScale: 10
    Text: I specialize in assisting the other two members in this vessel so I do
      know a thing or two about how things work around here.
  - Character:
      CharacterName: Thomas
      Portrait: {fileID: 21300000, guid: 2857a1a9d263fd148bd437f63cdd3e9e, type: 3}
      PortraitOffset: {x: -200, y: 200}
      PortraitScale: 10
    Text: "For today, I will guide you on how to work with the electrical wires.\r"
  - Character:
      CharacterName: Thomas
      Portrait: {fileID: 21300000, guid: 2857a1a9d263fd148bd437f63cdd3e9e, type: 3}
      PortraitOffset: {x: -200, y: 200}
      PortraitScale: 10
    Text: "While our Engineer Harold does a great work keeping this vessel afloat,
      he sometimes makes mistakes from rushing through maintenance.\r"
  - Character:
      CharacterName: Thomas
      Portrait: {fileID: 21300000, guid: 2857a1a9d263fd148bd437f63cdd3e9e, type: 3}
      PortraitOffset: {x: -200, y: 200}
      PortraitScale: 10
    Text: "The Electrical Breaker\u2026 Well, breaks! "
  - Character:
      CharacterName: Thomas
      Portrait: {fileID: 21300000, guid: 2857a1a9d263fd148bd437f63cdd3e9e, type: 3}
      PortraitOffset: {x: -200, y: 200}
      PortraitScale: 10
    Text: "The task should be simple.\r"
  - Character:
      CharacterName: Thomas
      Portrait: {fileID: 21300000, guid: 2857a1a9d263fd148bd437f63cdd3e9e, type: 3}
      PortraitOffset: {x: -200, y: 200}
      PortraitScale: 10
    Text: "Drag the wires correctly by looking for the correct colors on both ends.\r"
  - Character:
      CharacterName: Thomas
      Portrait: {fileID: 21300000, guid: 2857a1a9d263fd148bd437f63cdd3e9e, type: 3}
      PortraitOffset: {x: -200, y: 200}
      PortraitScale: 10
    Text: "Go to the Machine above me and give it a try.\r\r"
