--- !u!114 &30187185
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 30187184}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: a2b878c1b0778e244aa3bd0e9970ed64, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  _dialogueManager: {fileID: 1737419913}
  _dialogue:
  - Character:
      CharacterName: ???
      Portrait: {fileID: 21300000, guid: 90457a036e141744ea4cb1ce6bdbbf6b, type: 3}
      PortraitOffset: {x: -200, y: 200}
      PortraitScale: 5
    Text: "Who is this?! You\u2019re not supposed to be here!"
  - Character:
      CharacterName: ???
      Portrait: {fileID: 21300000, guid: 90457a036e141744ea4cb1ce6bdbbf6b, type: 3}
      PortraitOffset: {x: -200, y: 200}
      PortraitScale: 5
    Text: "Wait\u2026"
  - Character:
      CharacterName: ???
      Portrait: {fileID: 21300000, guid: 90457a036e141744ea4cb1ce6bdbbf6b, type: 3}
      PortraitOffset: {x: -200, y: 200}
      PortraitScale: 5
    Text: "Right\u2026 you must be the new Captain Thomas had told me about. I believe
      I should introduce myself."
  - Character:
      CharacterName: Harold
      Portrait: {fileID: 21300000, guid: 90457a036e141744ea4cb1ce6bdbbf6b, type: 3}
      PortraitOffset: {x: -200, y: 200}
      PortraitScale: 5
    Text: "The name\u2019s Harold and from what Thomas told you about me, yes I\u2019m
      the one who mostly maintains the Ocean Why ."
  - Character:
      CharacterName: Harold
      Portrait: {fileID: 21300000, guid: 90457a036e141744ea4cb1ce6bdbbf6b, type: 3}
      PortraitOffset: {x: -200, y: 200}
      PortraitScale: 5
    Text: "I\u2019ll be guiding you through one of tasks for the day since I got
      my hands tied at the moment working maintaining the vessel in another area."
  - Character:
      CharacterName: Harold
      Portrait: {fileID: 21300000, guid: 90457a036e141744ea4cb1ce6bdbbf6b, type: 3}
      PortraitOffset: {x: -200, y: 200}
      PortraitScale: 5
    Text: "Notice the Reactor Core on the side of the Deck? Head over there, I will
      show you how to work on it.\r"
